MONGO_URI=mongodb://localhost:27017/dental-clinic
JWT_SECRET=your_jwt_secret_key_here_change_in_production
PORT=5000
NODE_ENV=development

# Optional: one-time POST /api/auth/seed-admin to create the first admin (disabled if unset)
SETUP_SECRET=

# Default admin is auto-created when MongoDB connects AND no admin exists yet
# (defaults: admin@example.com / admin12345). On a new PC the DB is usually empty → bootstrap runs once.
# Disable auto-bootstrap in production with DISABLE_DEFAULT_ADMIN=true
# Override defaults:
# DEFAULT_ADMIN_EMAIL=you@yourdomain.com
# DEFAULT_ADMIN_PASSWORD=your_secure_password

# Single practice name for every dentist in this deployment (optional)
CLINIC_NAME=DentalClinic Network

# Used in password-reset emails (no trailing slash)
FRONTEND_URL=http://localhost:3000

# Optional SMTP — if omitted, reset links and reminders are logged to the console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Opt-in: daily 08:00 server time reminders for tomorrow's appointments (requires SMTP for real delivery)
REMINDER_EMAILS=false
